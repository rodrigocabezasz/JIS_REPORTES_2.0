# =============================================================================
# JIS Reportes 2.0 — plantilla maestra de variables de entorno
#
# ANTES DE DESARROLLAR (Fase 0): completar y verificar con:
#   python scripts/verify_connectivity.py
#
# Copiar a .env en la raíz (gitignored) y replicar en:
#   framework/agent-service-toolkit/.env
# (el servicio FastAPI del toolkit lee ese archivo al arrancar).
# =============================================================================

# -----------------------------------------------------------------------------
# MySQL — MISMA base que jisreportes.com (VPS)
# Desde tu PC: conexión directa si el VPS permite tu IP, o túnel SSH:
#   ssh -N -L 3307:localhost:3306 usuario@vps
# Entonces DB_HOST=127.0.0.1 y DB_PORT=3307
# -----------------------------------------------------------------------------
DB_HOST=
DB_PORT=3306
DB_DATABASE=

# Opción A — usuario/contraseña estándar
DB_USER=
DB_PASSWORD=

# Opción B — usuario solo lectura (soportado por jis_tools.py)
# DB_READONLY_USER=
# DB_READONLY_PASSWORD=

# -----------------------------------------------------------------------------
# MySQL secundario legacy (MachineJIS) — solo si alguna tool lo necesita
# -----------------------------------------------------------------------------
DB_HOST_MACHINEJIS=
DB_USER_MACHINEJIS=
DB_PASSWORD_MACHINEJIS=
DB_DATABASE_MACHINEJIS=
DB_PORT_MACHINEJIS=3306

# -----------------------------------------------------------------------------
# Ollama — JISLAB (HTTP; el modelo no se invoca por SSH)
#
# Misma LAN que JISLAB:
#   OLLAMA_BASE_URL=http://192.168.0.22:11434
#
# Con túnel SSH desde ESTA máquina (dejar terminal abierta):
#   ssh -N -L 11434:localhost:11434 usuario@jislab
#   OLLAMA_BASE_URL=http://127.0.0.1:11434
#
# El dominio público (ej. jisparking.from-vt.com) suele NO exponer el puerto 11434.
# -----------------------------------------------------------------------------
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5-coder:latest
DEFAULT_MODEL=ollama

# -----------------------------------------------------------------------------
# SSH — referencia para túneles y mantenimiento (no pegar comandos ssh sueltos como variables)
# -----------------------------------------------------------------------------
JISLAB_SSH_HOST=
JISLAB_SSH_USER=
JISLAB_SSH_PORT=22
# JISLAB_SSH_KEY_PATH=

# -----------------------------------------------------------------------------
# Backend agéntico — agent-service-toolkit / futuro Backend_V2
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8080
MODE=dev
# AUTH_SECRET=

DATABASE_TYPE=sqlite
SQLITE_DB_PATH=checkpoints.db

# Streamlit del toolkit
AGENT_URL=http://127.0.0.1:8080

# -----------------------------------------------------------------------------
# URL pública donde Meta / WhatsApp llegará al webhook (túnel Cloudflare, ngrok, etc.)
# Ejemplo: https://api-dev.jisreportes.com  (sin path; el path lo define el código)
# -----------------------------------------------------------------------------
PUBLIC_WEBHOOK_BASE_URL=

# -----------------------------------------------------------------------------
# WhatsApp / Meta Cloud API
# -----------------------------------------------------------------------------
META_APP_ID=
META_VERIFY_TOKEN=
META_ACCESS_TOKEN=
# A veces se documenta igual que el token de arriba:
WHATSAPP_TOKEN=
# ID del número de teléfono en Meta (Graph API)
WHATSAPP_PHONE_ID=
# Si tu panel muestra "Phone number ID" distinto del nombre de variable:
WHATSAPP_PHONE_NUMBER_ID=

# Opcional
# META_APP_SECRET=
# WHATSAPP_WABA_ID=
# WHATSAPP_BUSINESS_ID=

# -----------------------------------------------------------------------------
# jisreportes.com ACTUAL (legacy) — solo si pruebas front contra API vieja en local
# -----------------------------------------------------------------------------
# API_BASE_URL=https://api.jisreportes.com

# -----------------------------------------------------------------------------
# Opcional: LangSmith / Langfuse
# -----------------------------------------------------------------------------
# LANGCHAIN_TRACING_V2=false
# LANGCHAIN_API_KEY=
